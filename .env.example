EXPO_PUBLIC_API_BASE_URL=https://api.tmdb.org/3/

# NOTE: Exposing API credentials in a client-side app is not secure practice.
# In a production app this token should live in a backend proxy that your app
# calls, so the key is never shipped inside the JS bundle. We are doing it
# directly here for the purposes of this coding challenge only.
#
# TMDB API read access token (Bearer token, NOT the v3 API key)
# How to get it:
# 1. Create a free account at https://www.themoviedb.org/signup
# 2. Go to Settings → API → Request an API Key
# 3. Choose "Developer" and fill in the form
# 4. Copy the "API Read Access Token" (starts with "eyJ...") — NOT the short API Key
# 5. Paste it below
EXPO_PUBLIC_AND_UNSAFE_API_KEY=